#!/usr/bin/env sh
set -eu

CRON_DIR="${PHP_CRON_DIR:-/usr/local/etc/php/cron.d}"
COMBINED="${PHP_SUPERCRONIC_CRONTAB:-$CRON_DIR/.supercronic.cron}"

mkdir -p "$CRON_DIR"

if [ ! -s "$COMBINED" ]; then
  echo "No Supercronic crontab found at $COMBINED; cron service is idle. Run manage.py cron create, then restart this container once."
  exec sleep infinity
fi

echo "Starting supercronic with crontab $COMBINED"
exec /usr/local/bin/supercronic -passthrough-logs "$COMBINED"
