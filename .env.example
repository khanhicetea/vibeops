# Copy to .env and edit before `./dc up -d`.
TZ=Asia/Ho_Chi_Minh
# Bounded Docker stdout/stderr retention for every service (local driver).
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=5
MYSQL_ROOT_PASSWORD=change-me-long-random-password
# Optional per-version root passwords override MYSQL_ROOT_PASSWORD.
# MYSQL57_ROOT_PASSWORD=change-me-long-random-password
# MYSQL84_ROOT_PASSWORD=change-me-long-random-password
# MYSQL97_ROOT_PASSWORD=change-me-long-random-password
DEFAULT_MYSQL_SERVICE=mysql84
# Optional MySQL majors; mysql84 is the default service.
# MYSQL57_VERSION=5.7
MYSQL84_VERSION=8.4
# MYSQL97_VERSION=9.7

# InnoDB buffer pool. Must be a multiple of 128M (chunk size). Examples:
# 256M small VPS, 512M default (mysql84/mysql97), 384M default (mysql57),
# 1G–2G multi-site hosts dedicated to this stack.
# Leave headroom for OS, PHP-FPM, Nginx, and Redis — do not set to all free RAM.
MYSQL_INNODB_BUFFER_POOL_SIZE=512M

# Shared Redis is the compatibility default. REDIS_PASSWORD may be empty for old installs.
REDIS_APP_ACL=false
REDIS_PASSWORD=change-me-long-random-shared-password
# Set true for one ACL username/password per app and enforced <app>:* key isolation.
# ACL mode requires REDIS_ADMIN_PASSWORD. Values may contain letters, digits, . _ ~ - only.
# REDIS_APP_ACL=true
# REDIS_ADMIN_PASSWORD=change-me-long-random-redis-admin-password
# Optional password-only default user while ACL mode is enabled; weakens isolation.
# REDIS_LEGACY_PASSWORD=change-me-long-random-legacy-password
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# PHP services shipped by default. Add more with a compose.d fragment based on php85.
DEFAULT_PHP_VERSION=8.4
PHP84_VERSION=8.4
PHP85_VERSION=8.5

# Default PHP-FPM pool profile for new apps: ondemand | balanced | throughput.
# Per-app override: ./manage.py app create <app> <domain> --fpm-profile ondemand
DEFAULT_FPM_PROFILE=balanced
# Global PHP-FPM process.max baked into PHP images at build time (safety cap).
# Per-pool max_children is additionally bounded by this value. Rebuild PHP
# services after changing: docker compose build php84 php85
# PHP_FPM_PROCESS_MAX=32

# Official Debian nginx runs workers as group id 101. PHP-FPM sockets are created
# with this GID so host-network nginx can access unix sockets shared at ./runtime/run/php-fpm/phpXX.
SOCKET_GID=101

# App-scoped nginx access logs (opt-in per app: ./manage.py app access-log enable <app>).
# Live files live under runtime/logs/nginx/apps/<app>.access.log. Rotation renames the
# live file then runs `nginx -s reopen` (does not reload config or drop connections).
NGINX_ACCESS_LOG_MAX_SIZE=100M
NGINX_ACCESS_LOG_ROTATE=14
# Docker image for adhoc GoAccess: ./manage.py app logs analyze <app>
# GOACCESS_IMAGE=allinurl/goaccess:latest

# PHP startup synchronizes rendered Linux identities only. Use `manage.py permissions`
# check/fix explicitly when app filesystem ownership or modes need repair.

