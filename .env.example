# Copy to .env and edit before `docker compose up -d`.
TZ=Asia/Ho_Chi_Minh
# Bounded Docker stdout/stderr retention for every service (local driver).
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=5
MYSQL_ROOT_PASSWORD=change-me-long-random-password
# Optional per-version root passwords override MYSQL_ROOT_PASSWORD.
# MYSQL57_ROOT_PASSWORD=change-me-long-random-password
# MYSQL84_ROOT_PASSWORD=change-me-long-random-password
# MYSQL97_ROOT_PASSWORD=change-me-long-random-password
DEFAULT_MYSQL_SERVICE=mysql84
# Optional MySQL majors; mysql84 is the default service.
# MYSQL57_VERSION=5.7
MYSQL84_VERSION=8.4
# MYSQL97_VERSION=9.7

# InnoDB buffer pool. Must be a multiple of 128M (chunk size). Examples:
# 256M small VPS, 512M default (mysql84/mysql97), 384M default (mysql57),
# 1G–2G multi-site hosts dedicated to this stack.
# Leave headroom for OS, PHP-FPM, Nginx, and Redis — do not set to all free RAM.
MYSQL_INNODB_BUFFER_POOL_SIZE=512M

# PHP services shipped by default. Add more by copying php85 in compose.yml.
DEFAULT_PHP_VERSION=8.4
PHP84_VERSION=8.4
PHP85_VERSION=8.5

# Official Debian nginx runs workers as group id 101. PHP-FPM sockets are created
# with this GID so host-network nginx can access unix sockets shared at ./runtime/run/php-fpm/phpXX.
SOCKET_GID=101

# PHP startup synchronizes rendered Linux identities only. Use `manage.py permissions`
# check/fix explicitly when app filesystem ownership or modes need repair.

