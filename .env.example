# Copy to .env and edit before `docker compose up -d`.
TZ=Asia/Ho_Chi_Minh
MYSQL_ROOT_PASSWORD=change-me-long-random-password
# Optional per-version root passwords override MYSQL_ROOT_PASSWORD.
# MYSQL57_ROOT_PASSWORD=change-me-long-random-password
# MYSQL84_ROOT_PASSWORD=change-me-long-random-password
# MYSQL97_ROOT_PASSWORD=change-me-long-random-password
DEFAULT_MYSQL_SERVICE=mysql84
# Optional MySQL majors; mysql84 is the default service.
# MYSQL57_VERSION=5.7
MYSQL84_VERSION=8.4
# MYSQL97_VERSION=9.7

# PHP services shipped by default. Add more by copying php85 in compose.yml.
DEFAULT_PHP_VERSION=8.4
PHP84_VERSION=8.4
PHP85_VERSION=8.5

# Official Debian nginx runs workers as group id 101. PHP-FPM sockets are created
# with this GID so host-network nginx can access unix sockets shared at ./runtime/run/php-fpm/phpXX.
SOCKET_GID=101

# Good DX default: container startup fixes /home/<user> ownership for generated users.
# Disable for very large homes and manage ownership yourself.
FIX_HOME_OWNERSHIP=1

