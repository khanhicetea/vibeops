[mysqld]
# Shared defaults that are intentionally compatible across MySQL 5.7, 8.4, and 9.7.
bind-address = 0.0.0.0
skip_name_resolve

# Safer application defaults.
local_infile = 0
symbolic-links = 0
max_allowed_packet = 64M
max_connections = 150
open_files_limit = 65535
wait_timeout = 300

# Conservative per-session buffers to avoid memory spikes under concurrency.
read_buffer_size = 1M
read_rnd_buffer_size = 2M
sort_buffer_size = 2M
join_buffer_size = 1M
tmp_table_size = 64M
max_heap_table_size = 64M
table_open_cache = 2000

# utf8mb4 everywhere by default.
character_set_server = utf8mb4
collation_server = utf8mb4_unicode_ci

# InnoDB baseline.
innodb_file_per_table = 1
innodb_flush_method = O_DIRECT
innodb_io_capacity = 400
innodb_log_buffer_size = 16M
innodb_strict_mode = 1
