[mysqld]
# MySQL 5.7 compatibility defaults for legacy apps.
default_authentication_plugin = mysql_native_password
explicit_defaults_for_timestamp = 1
sql_mode = STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION

# 5.7 uses innodb_log_file_size instead of the 8.x/9.x redo capacity setting.
# innodb_buffer_pool_size is set via compose command (MYSQL_INNODB_BUFFER_POOL_SIZE).
innodb_log_file_size = 128M
