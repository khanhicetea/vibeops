# VibeOps local/runtime/user data
# Keep source config/templates tracked; ignore generated tenant/runtime data.

# Local secrets/config
.env
.env.*
!.env.example
stack.json

# Runtime mutable state
/runtime/home/*
!/runtime/home/.gitkeep

/runtime/logs/*
!/runtime/logs/.gitkeep
!/runtime/logs/nginx/
/runtime/logs/nginx/*
!/runtime/logs/nginx/.gitkeep
!/runtime/logs/php/
!/runtime/logs/php/php84/
!/runtime/logs/php/php84/.gitkeep
!/runtime/logs/php/php85/
!/runtime/logs/php/php85/.gitkeep

/runtime/backups/*
!/runtime/backups/.gitkeep
!/runtime/backups/mysql/
/runtime/backups/mysql/*
!/runtime/backups/mysql/.gitkeep

/runtime/acme-challenge/*
!/runtime/acme-challenge/.gitkeep
/runtime/certs/*
!/runtime/certs/.gitignore
!/runtime/certs/.gitkeep
/runtime/nginx-acme-state/*
!/runtime/nginx-acme-state/.gitignore
!/runtime/nginx-acme-state/.gitkeep

/runtime/nginx/vhosts/*
!/runtime/nginx/vhosts/.gitkeep

/runtime/cron/*
!/runtime/cron/php84/
!/runtime/cron/php84/jobs/
!/runtime/cron/php84/jobs/.gitkeep
!/runtime/cron/php85/
!/runtime/cron/php85/jobs/
!/runtime/cron/php85/jobs/.gitkeep
/runtime/cron/php*/jobs/*.cron
/runtime/cron/php*/.supercronic.cron

/runtime/run/*
!/runtime/run/.gitkeep
!/runtime/run/php-fpm/
!/runtime/run/php-fpm/php84/
!/runtime/run/php-fpm/php84/.gitkeep
!/runtime/run/php-fpm/php85/
!/runtime/run/php-fpm/php85/.gitkeep

# Generated PHP users and pools
/config/php/versions/*/users.d/*
!/config/php/versions/*/users.d/.gitkeep
/config/php/versions/*/pool.d/*.conf
!/config/php/versions/*/pool.d/zz-health.conf
!/config/php/versions/*/pool.d/.gitkeep

# Dumps/cache/runtime files
*.sql
*.sql.gz
*.dump
*.bak
*.sock
*.pid

# Editor/OS noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Python
__pycache__/
