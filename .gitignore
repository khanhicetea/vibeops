# VibeOps local/runtime/user data
# Keep source config/templates tracked; ignore generated tenant/runtime data.

# Local secrets/config
.env
.env.*
!.env.example
stack.json
compose.override.yml
compose.local.yml
compose.d/*.yml

# Runtime state, generated config, customization, and mutable data
/runtime/state/*
!/runtime/state/.gitkeep

/runtime/generated/*
!/runtime/generated/.gitkeep
!/runtime/generated/nginx/
!/runtime/generated/nginx/vhosts/
!/runtime/generated/nginx/vhosts/.gitkeep
!/runtime/generated/php/
!/runtime/generated/php/versions/
!/runtime/generated/php/versions/8.4/
!/runtime/generated/php/versions/8.4/pool.d/
!/runtime/generated/php/versions/8.4/pool.d/.gitkeep
!/runtime/generated/php/versions/8.4/users.d/
!/runtime/generated/php/versions/8.4/users.d/.gitkeep
!/runtime/generated/php/versions/8.5/
!/runtime/generated/php/versions/8.5/pool.d/
!/runtime/generated/php/versions/8.5/pool.d/.gitkeep
!/runtime/generated/php/versions/8.5/users.d/
!/runtime/generated/php/versions/8.5/users.d/.gitkeep
!/runtime/generated/cron/
!/runtime/generated/cron/php84/
!/runtime/generated/cron/php84/jobs/
!/runtime/generated/cron/php84/jobs/.gitkeep
!/runtime/generated/cron/php85/
!/runtime/generated/cron/php85/jobs/
!/runtime/generated/cron/php85/jobs/.gitkeep
/runtime/generated/nginx/vhosts/*.conf
/runtime/generated/php/versions/*/users.d/*
!/runtime/generated/php/versions/*/users.d/.gitkeep
/runtime/generated/php/versions/*/pool.d/*.conf
!/runtime/generated/php/versions/*/pool.d/.gitkeep
/runtime/generated/cron/php*/jobs/*.cron
/runtime/generated/cron/php*/.supercronic.cron

/runtime/custom/*
!/runtime/custom/.gitkeep
!/runtime/custom/nginx/
!/runtime/custom/nginx/.gitkeep
!/runtime/custom/php/
!/runtime/custom/php/.gitkeep
!/runtime/custom/mysql/
!/runtime/custom/mysql/.gitkeep

/runtime/home/*
!/runtime/home/.gitkeep

/runtime/logs/*
!/runtime/logs/.gitkeep
!/runtime/logs/nginx/
/runtime/logs/nginx/*
!/runtime/logs/nginx/.gitkeep
!/runtime/logs/php/
!/runtime/logs/php/php84/
!/runtime/logs/php/php84/.gitkeep
!/runtime/logs/php/php85/
!/runtime/logs/php/php85/.gitkeep
!/runtime/logs/mysql57/
!/runtime/logs/mysql57/.gitkeep
!/runtime/logs/mysql84/
!/runtime/logs/mysql84/.gitkeep
!/runtime/logs/mysql97/
!/runtime/logs/mysql97/.gitkeep
/runtime/logs/mysql*/*
!/runtime/logs/mysql*/.gitkeep

/runtime/backups/*
!/runtime/backups/.gitkeep
!/runtime/backups/mysql/
/runtime/backups/mysql/*
!/runtime/backups/mysql/.gitkeep
!/runtime/backups/mysql57/
!/runtime/backups/mysql57/.gitkeep
!/runtime/backups/mysql84/
!/runtime/backups/mysql84/.gitkeep
!/runtime/backups/mysql97/
!/runtime/backups/mysql97/.gitkeep
/runtime/backups/mysql*/*
!/runtime/backups/mysql*/.gitkeep

/runtime/acme-challenge/*
!/runtime/acme-challenge/.gitkeep
/runtime/certs/*
!/runtime/certs/.gitignore
!/runtime/certs/.gitkeep
/runtime/nginx-acme-state/*
!/runtime/nginx-acme-state/.gitignore
!/runtime/nginx-acme-state/.gitkeep

/runtime/nginx/vhosts/*
!/runtime/nginx/vhosts/.gitkeep

/runtime/cron/*
!/runtime/cron/php84/
!/runtime/cron/php84/jobs/
!/runtime/cron/php84/jobs/.gitkeep
!/runtime/cron/php85/
!/runtime/cron/php85/jobs/
!/runtime/cron/php85/jobs/.gitkeep
/runtime/cron/php*/jobs/*.cron
/runtime/cron/php*/.supercronic.cron

/runtime/run/*
!/runtime/run/.gitkeep
!/runtime/run/php-fpm/
!/runtime/run/php-fpm/php84/
!/runtime/run/php-fpm/php84/.gitkeep
!/runtime/run/php-fpm/php85/
!/runtime/run/php-fpm/php85/.gitkeep

# Dumps/cache/runtime files
*.sql
*.sql.gz
*.dump
*.bak
*.sock
*.pid

# Editor/OS noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Python
__pycache__/
