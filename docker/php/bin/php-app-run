#!/usr/bin/env sh
set -eu

if [ "$#" -lt 3 ]; then
  echo "Usage: php-app-run <app> <workdir> <command> [args...]" >&2
  exit 2
fi

app="$1"
workdir="$2"
shift 2
php-identity-sync "$app"
# Repair only policy directories here, never an existing app tree. This gives a
# newly-created app's shell a setgid document root before it creates files.
php-permissions fix "$app"
exec php-cron-as "$app" "$workdir" "$@"
