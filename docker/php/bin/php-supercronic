#!/usr/bin/env sh
set -eu

CRON_DIR="${PHP_CRON_DIR:-/usr/local/etc/php/cron.d}"
COMBINED="${1:-${PHP_SUPERCRONIC_CRONTAB:-$CRON_DIR/system.cron}}"

if [ ! -s "$COMBINED" ]; then
  echo "Supercronic crontab is missing or empty: $COMBINED" >&2
  echo "Run ./manage.py render before starting the runner service." >&2
  exit 1
fi

# Supervisord is PID 1 and reaps zombies; -no-reap avoids the noisy
# "process reaping disabled, not pid 1" warning under the runner.
/usr/local/bin/supercronic -no-reap -test "$COMBINED"
echo "Starting supercronic with crontab $COMBINED"
exec /usr/local/bin/supercronic -no-reap -json -split-logs "$COMBINED"
