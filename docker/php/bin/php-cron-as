#!/usr/bin/env sh
# Run one scheduled command as an app's private UID/GID. This helper validates
# runtime inputs and drops privileges only; it never provisions or repairs files.
set -eu

if [ "$#" -lt 8 ]; then
  echo "Usage: php-cron-as <user> <job> <workdir> <docker|file> <timeout-seconds> <lock|-> <php-service> <command> [args...]" >&2
  exit 2
fi

APP_USER="$1"
APP_JOB="$2"
APP_WORKDIR="$3"
OUTPUT="$4"
TIMEOUT="$5"
LOCK="$6"
PHP_SERVICE="$7"
shift 7

case "$APP_USER" in ''|*[!a-z0-9_-]*|[0-9_-]*) echo "Invalid app user: $APP_USER" >&2; exit 2;; esac
case "$APP_JOB" in ''|*[!A-Za-z0-9_.-]*) echo "Invalid cron job: $APP_JOB" >&2; exit 2;; esac
case "$OUTPUT" in docker|file) ;; *) echo "Invalid output mode: $OUTPUT" >&2; exit 2;; esac
case "$TIMEOUT" in ''|*[!0-9]*) echo "Invalid timeout: $TIMEOUT" >&2; exit 2;; esac
case "$LOCK" in -) ;; ''|*[!A-Za-z0-9_.-]*) echo "Invalid lock name: $LOCK" >&2; exit 2;; esac
case "$PHP_SERVICE" in ''|*[!a-z0-9-]*) echo "Invalid PHP service: $PHP_SERVICE" >&2; exit 2;; php[0-9]*-cron) ;; *) echo "Invalid PHP service: $PHP_SERVICE" >&2; exit 2;; esac

APP_HOME="/home/$APP_USER"
APP_COMPOSER_HOME="$APP_HOME/.composer"
APP_LOG="$APP_HOME/logs/cron-$PHP_SERVICE-$APP_JOB.log"

if ! id "$APP_USER" >/dev/null 2>&1; then
  echo "Unknown app user: $APP_USER" >&2
  exit 1
fi
case "$APP_WORKDIR" in "$APP_HOME"|"$APP_HOME"/*) ;; *) echo "Workdir must be inside $APP_HOME: $APP_WORKDIR" >&2; exit 1;; esac
case "$APP_WORKDIR" in *'/../'*|*/..|*'/./'*|*/.) echo "Workdir contains unsafe path components: $APP_WORKDIR" >&2; exit 1;; esac
if [ ! -d "$APP_WORKDIR" ]; then
  echo "Workdir does not exist: $APP_WORKDIR" >&2
  exit 1
fi
resolved_home="$(readlink -f "$APP_HOME")"
resolved_workdir="$(readlink -f "$APP_WORKDIR")"
case "$resolved_workdir" in "$resolved_home"|"$resolved_home"/*) ;; *) echo "Resolved workdir escapes $APP_HOME: $APP_WORKDIR" >&2; exit 1;; esac
if [ ! -d "$APP_COMPOSER_HOME" ]; then
  echo "Composer home is missing; run: manage.py permissions fix $APP_USER" >&2
  exit 1
fi
if [ "$OUTPUT" = file ] && [ ! -d "$APP_HOME/logs" ]; then
  echo "App log directory is missing; run: manage.py permissions fix $APP_USER" >&2
  exit 1
fi

cd "$APP_WORKDIR"
umask 0027
exec gosu "$APP_USER" env \
  HOME="$APP_HOME" \
  USER="$APP_USER" \
  LOGNAME="$APP_USER" \
  COMPOSER_HOME="$APP_COMPOSER_HOME" \
  VIBEOPS_APP="$APP_USER" \
  VIBEOPS_CRON_JOB="$APP_JOB" \
  VIBEOPS_CRON_OUTPUT="$OUTPUT" \
  VIBEOPS_PHP_SERVICE="$PHP_SERVICE" \
  sh -c '
    output="$1"; timeout_seconds="$2"; lock_name="$3"; log_file="$4"; shift 4
    if [ "$lock_name" != "-" ]; then
      set -- flock -n "/run/vibeops-cron-locks/${VIBEOPS_APP}/${lock_name}.lock" -- "$@"
    fi
    if [ "$timeout_seconds" -gt 0 ]; then
      set -- timeout --foreground --kill-after=30 "$timeout_seconds" "$@"
    fi
    if [ "$output" = file ]; then
      exec "$@" >>"$log_file" 2>&1
    fi
    exec "$@"
  ' cron-runner "$OUTPUT" "$TIMEOUT" "$LOCK" "$APP_LOG" "$@"
